{
  "manifest_version": 3,
  "name": "DevClock",
  "version": "1.4.0",
  "description": "Convert timestamps across configurable timezones and generate copy-ready log query windows for Splunk, Grafana, and CloudWatch.",
  "action": {
    "default_popup": "converter-popup.html",
    "default_title": "DevClock",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "options_page": "options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Open DevClock"
    }
  },
  "homepage_url": "https://kokilaw.github.io/dev-clock-extension/privacy-policy.html",
  "permissions": [
    "storage",
    "clipboardRead",
    "contextMenus"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
